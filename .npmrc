auto-install-peers=true
strict-peer-dependencies=false

# 国内网络访问 npmjs 易超时，使用 npmmirror（原淘宝镜像）
registry=https://registry.npmmirror.com

# @langchain 包同步较慢，走官方源以拿到最新 langgraph-cli / langgraph-api
@langchain:registry=https://registry.npmjs.org

# 降低并发、延长超时，减少 ETIMEDOUT
fetch-timeout=600000
fetch-retries=5
network-concurrency=4
