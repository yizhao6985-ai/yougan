{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**"]
    },
    "openapi:generate": {
      "cache": false,
      "outputs": ["openapi/openapi.json"]
    },
    "generate:api": {
      "dependsOn": ["@yougan/api#openapi:generate"],
      "cache": false,
      "outputs": ["src/lib/api/schema.d.ts"]
    }
  }
}
