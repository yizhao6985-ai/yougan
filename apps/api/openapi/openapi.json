{
  "openapi": "3.0.3",
  "info": {
    "title": "Yougan API",
    "version": "0.1.0",
    "description": "有感 Yougan 中间层：账号鉴权、作品管理、OSS 上传、Agent 流转发。"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "bio": {
            "type": "string",
            "nullable": true
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "coverUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "bio",
          "avatarUrl",
          "coverUrl",
          "createdAt"
        ]
      },
      "AuthToken": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        },
        "required": [
          "token",
          "user"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "UpdateProfile": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "bio": {
            "type": "string",
            "maxLength": 160
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "coverUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "currentPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "minLength": 6
          }
        }
      },
      "PlatformIntegration": {
        "type": "object",
        "nullable": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          },
          "accountName": {
            "type": "string",
            "nullable": true
          },
          "accountId": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tokenExpiresAt": {
            "type": "string",
            "nullable": true
          },
          "connectedAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "platform",
          "accountName",
          "accountId",
          "status",
          "scopes",
          "tokenExpiresAt",
          "connectedAt",
          "updatedAt"
        ]
      },
      "PlatformCatalogItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "oauthConfigured": {
            "type": "boolean"
          },
          "connected": {
            "type": "boolean"
          },
          "integration": {
            "$ref": "#/components/schemas/PlatformIntegration"
          }
        },
        "required": [
          "id",
          "label",
          "description",
          "oauthConfigured",
          "connected",
          "integration"
        ]
      },
      "WorkGroup": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "createdAt",
          "updatedAt"
        ]
      },
      "WorkProfile": {
        "type": "object",
        "properties": {
          "platform": {
            "type": "string",
            "nullable": true
          },
          "content_topic": {
            "type": "string",
            "nullable": true
          },
          "content_type": {
            "type": "string",
            "nullable": true
          },
          "content_format": {
            "type": "string",
            "nullable": true
          },
          "media_modality": {
            "type": "string",
            "nullable": true
          },
          "content_points": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "style": {
            "type": "string",
            "nullable": true
          },
          "tone": {
            "type": "string",
            "nullable": true
          },
          "persona": {
            "type": "string",
            "nullable": true
          },
          "audience": {
            "type": "string",
            "nullable": true
          },
          "goals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "style_constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "references": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": {
                "nullable": true
              }
            }
          }
        }
      },
      "WorkOutline": {
        "type": "object",
        "properties": {
          "pending_changes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "description",
                "created_at"
              ]
            }
          },
          "executed_changes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "executed_at": {
                  "type": "string"
                },
                "batch_summary": {
                  "type": "string",
                  "nullable": true
                }
              },
              "required": [
                "id",
                "description",
                "executed_at"
              ]
            }
          },
          "last_execution_summary": {
            "type": "string",
            "nullable": true
          },
          "outline_summary": {
            "type": "string",
            "nullable": true
          },
          "outline_ready": {
            "type": "boolean"
          }
        },
        "required": [
          "pending_changes",
          "executed_changes"
        ]
      },
      "WorkInspiration": {
        "type": "object",
        "properties": {
          "confirmed_requirements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "confirmed_at": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "description",
                "confirmed_at"
              ]
            }
          },
          "summary": {
            "type": "string",
            "nullable": true
          },
          "inspiration_ready": {
            "type": "boolean"
          },
          "summarized_at": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "confirmed_requirements"
        ]
      },
      "GeneratedContent": {
        "type": "object",
        "nullable": true,
        "properties": {
          "platform": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "body": {
            "type": "string"
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hook": {
            "type": "string",
            "nullable": true
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": {
                "nullable": true
              }
            }
          },
          "publish_ready": {
            "type": "boolean"
          }
        },
        "required": [
          "platform",
          "body"
        ]
      },
      "Work": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "groupId": {
            "type": "string",
            "nullable": true
          },
          "mode": {
            "type": "string",
            "enum": [
              "inspiration",
              "outline",
              "creation"
            ]
          },
          "threadId": {
            "type": "string",
            "nullable": true
          },
          "profile": {
            "$ref": "#/components/schemas/WorkProfile"
          },
          "outline": {
            "$ref": "#/components/schemas/WorkOutline"
          },
          "inspiration": {
            "$ref": "#/components/schemas/WorkInspiration"
          },
          "creation": {
            "$ref": "#/components/schemas/GeneratedContent"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "groupId",
          "mode",
          "threadId",
          "profile",
          "outline",
          "inspiration",
          "creation",
          "createdAt",
          "updatedAt"
        ]
      },
      "SyncWorkState": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "inspiration",
              "outline",
              "creation"
            ]
          },
          "threadId": {
            "type": "string",
            "nullable": true
          },
          "groupId": {
            "type": "string",
            "nullable": true
          },
          "profile": {
            "$ref": "#/components/schemas/WorkProfile"
          },
          "outline": {
            "$ref": "#/components/schemas/WorkOutline"
          },
          "inspiration": {
            "$ref": "#/components/schemas/WorkInspiration"
          },
          "creation": {
            "$ref": "#/components/schemas/GeneratedContent"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "AgentContext": {
        "type": "object",
        "properties": {
          "workId": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "inspiration",
              "outline",
              "creation"
            ]
          },
          "profile": {
            "$ref": "#/components/schemas/WorkProfile"
          },
          "outline": {
            "$ref": "#/components/schemas/WorkOutline"
          },
          "inspiration": {
            "$ref": "#/components/schemas/WorkInspiration"
          },
          "creation": {
            "$ref": "#/components/schemas/GeneratedContent"
          }
        },
        "required": [
          "workId",
          "mode",
          "profile",
          "outline",
          "inspiration",
          "creation"
        ]
      },
      "InspirationRecommendation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "suggestion"
        ]
      },
      "WorkInspirationRecommendations": {
        "type": "object",
        "properties": {
          "workId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "recommendations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InspirationRecommendation"
            },
            "minItems": 1,
            "maxItems": 5
          }
        },
        "required": [
          "workId",
          "title",
          "recommendations"
        ]
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "key": {
            "type": "string"
          }
        },
        "required": [
          "url",
          "key"
        ]
      },
      "SubscriptionPlan": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "monthlyAiQuota": {
            "type": "integer"
          },
          "priceMonthlyLabel": {
            "type": "string"
          },
          "priceYearlyLabel": {
            "type": "string"
          },
          "priceMonthlyCents": {
            "type": "integer"
          },
          "priceYearlyCents": {
            "type": "integer"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "highlighted": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "monthlyAiQuota",
          "priceMonthlyLabel",
          "priceYearlyLabel",
          "priceMonthlyCents",
          "priceYearlyCents",
          "features",
          "highlighted"
        ]
      },
      "SubscriptionSummary": {
        "type": "object",
        "properties": {
          "planId": {
            "type": "string"
          },
          "planName": {
            "type": "string"
          },
          "planDescription": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "billingCycle": {
            "type": "string",
            "nullable": true,
            "enum": [
              "monthly",
              "yearly"
            ]
          },
          "currentPeriodStart": {
            "type": "string"
          },
          "currentPeriodEnd": {
            "type": "string",
            "nullable": true
          },
          "aiUsageThisPeriod": {
            "type": "integer"
          },
          "aiQuotaThisPeriod": {
            "type": "integer"
          },
          "cancelAtPeriodEnd": {
            "type": "boolean"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "planId",
          "planName",
          "planDescription",
          "status",
          "billingCycle",
          "currentPeriodStart",
          "currentPeriodEnd",
          "aiUsageThisPeriod",
          "aiQuotaThisPeriod",
          "cancelAtPeriodEnd",
          "features"
        ]
      },
      "BillingOrder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "planId": {
            "type": "string"
          },
          "planName": {
            "type": "string"
          },
          "billingCycle": {
            "type": "string",
            "enum": [
              "monthly",
              "yearly"
            ]
          },
          "amountCents": {
            "type": "integer"
          },
          "amountLabel": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "paidAt": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "planId",
          "planName",
          "billingCycle",
          "amountCents",
          "amountLabel",
          "currency",
          "status",
          "description",
          "paidAt",
          "createdAt"
        ]
      },
      "CheckoutSubscription": {
        "type": "object",
        "properties": {
          "planId": {
            "type": "string",
            "enum": [
              "pro"
            ]
          },
          "billingCycle": {
            "type": "string",
            "enum": [
              "monthly",
              "yearly"
            ]
          }
        },
        "required": [
          "planId",
          "billingCycle"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6
                  },
                  "name": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthToken"
                }
              }
            }
          },
          "409": {
            "description": "Email exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged in",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthToken"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  },
                  "required": [
                    "user"
                  ]
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfile"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  },
                  "required": [
                    "user"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                },
                "required": [
                  "email"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset email requested",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "minLength": 1
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6
                  }
                },
                "required": [
                  "token",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid token or password",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "204": {
            "description": "Logged out"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/integrations": {
      "get": {
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Platform integration catalog",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "platforms": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PlatformCatalogItem"
                      }
                    }
                  },
                  "required": [
                    "platforms"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/integrations/{platform}/authorize": {
      "post": {
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "platform",
            "in": "path"
          }
        ],
