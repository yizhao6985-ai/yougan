generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(cuid())
  email                String?               @unique
  phone                String?               @unique
  passwordHash         String?
  phoneVerifiedAt      DateTime?
  name                 String?
  bio                  String?
  avatarUrl            String?
  coverUrl             String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  works                Work[]
  workGroups           WorkGroup[]
  publications         Publication[]
  passwordResetTokens  PasswordResetToken[]
  emailChangeTokens    EmailChangeToken[]
  subscription         UserSubscription?
  billingOrders        BillingOrder[]
}

model EmailChangeToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model UserSubscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// free | pro | pro_plus
  planId             String    @default("free")
  /// active | canceled | expired
  status             String    @default("active")
  /// monthly | yearly，免费版为 null
  billingCycle       String?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  /// 本周期已消耗 API 预算（microCredits；1 = ¥0.0001）
  aiUsageMicroCredits Int      @default(0)
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([planId, status])
}

model AiUsageSettlement {
  id              String   @id @default(cuid())
  userId          String
  idempotencyKey  String
  microCredits    Int
  createdAt       DateTime @default(now())

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt(sort: Desc)])
}

model BillingOrder {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId       String
  billingCycle String
  amountCents  Int
  currency     String    @default("CNY")
  /// pending | paid | failed | refunded
  status       String    @default("pending")
  description  String
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model WorkGroup {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  works     Work[]

  @@index([userId, updatedAt(sort: Desc)])
}

model Work {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId            String?
  group              WorkGroup?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  title              String
  /// 当前 head version
  headVersionId     String?
  /// 若由另存为新作品创建，记录来源
  sourceWorkId       String?
  sourceVersionId   String?
  /// 物化视图：创作方案（direction、style、context、sequence、bounds；不含 references）
  profile            Json                @default("{}")
  /// 物化视图：参考素材
  references         Json                @default("[]")
  /// 物化视图：制作环节（内部计划 + 作品预览）
  production         Json                @default("{}")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  publications       Publication[]
  conversations      WorkConversation[]
  versions          WorkVersion[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, groupId, updatedAt(sort: Desc)])
}

/// 作品版本节点（单线时间轴）
model WorkVersion {
  id               String   @id @default(cuid())
  workId           String
  work             Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  parentVersionId String?
  conversationId   String?
  kind             String
  summary          String
  snapshot         Json
  createdAt        DateTime @default(now())

  @@index([workId, createdAt(sort: Desc)])
}

/// 作品下的多轮对话；共享同一份作品状态，messages 存 LangGraph thread checkpoint
model WorkConversation {
  id        String   @id @default(cuid())
  workId    String
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  title     String   @default("对话")
  threadId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId, updatedAt(sort: Desc)])
}

model Publication {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workId        String?
  work          Work?     @relation(fields: [workId], references: [id], onDelete: SetNull)
  slug          String    @unique
  title         String
  excerpt       String?
  blocks        Json      @default("[]")
  coverUrl          String?
  coverBlockId      String?
  compositionLabel  String?
  consumptionHint   String?
  blockComposition  Json      @default("{}")
  contentFormat     String?
  topicCategory String?
  contentTopic  String?
  contentType   String?
  mediaTypes    String[]  @default([])
  hashtags      Json      @default("[]")
  status        String    @default("draft")
  viewCount     Int       @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status, updatedAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, contentFormat, publishedAt(sort: Desc)])
  @@index([status, topicCategory, publishedAt(sort: Desc)])
  @@index([status, mediaTypes, publishedAt(sort: Desc)])
}
