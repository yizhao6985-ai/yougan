generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String
  name                 String?
  bio                  String?
  avatarUrl            String?
  coverUrl             String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  works                Work[]
  workGroups           WorkGroup[]
  platformIntegrations PlatformIntegration[]
  publications         Publication[]
  passwordResetTokens  PasswordResetToken[]
  emailChangeTokens    EmailChangeToken[]
  subscription         UserSubscription?
  billingOrders        BillingOrder[]
}

model EmailChangeToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model UserSubscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// free | pro
  planId             String    @default("free")
  /// active | canceled | expired
  status             String    @default("active")
  /// monthly | yearly，免费版为 null
  billingCycle       String?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  aiUsageThisPeriod  Int       @default(0)
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([planId, status])
}

model BillingOrder {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId       String
  billingCycle String
  amountCents  Int
  currency     String    @default("CNY")
  /// pending | paid | failed | refunded
  status       String    @default("pending")
  description  String
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model PlatformIntegration {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       String
  accountName    String?
  accountId      String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  scopes         Json      @default("[]")
  status         String    @default("connected")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId, updatedAt(sort: Desc)])
}

model WorkGroup {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  works     Work[]

  @@index([userId, updatedAt(sort: Desc)])
}

model Work {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId            String?
  group              WorkGroup?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  title              String
  /// 当前 head revision
  headRevisionId     String?
  /// 若由另存为新作品创建，记录来源
  sourceWorkId       String?
  sourceRevisionId   String?
  /// 物化视图：跨模式 profile（参考素材）
  profile            Json                @default("{}")
  /// 物化视图：作品方案（用户可见）
  blueprint          Json                @default("{}")
  /// 物化视图：内部创作计划（不对用户展示）
  plan               Json                @default("{}")
  /// 物化视图：最新成稿
  draft              Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  publications       Publication[]
  conversations      WorkConversation[]
  revisions          WorkRevision[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, groupId, updatedAt(sort: Desc)])
}

/// 作品版本节点（单线时间轴）
model WorkRevision {
  id               String   @id @default(cuid())
  workId           String
  work             Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  parentRevisionId String?
  conversationId   String?
  kind             String
  summary          String
  snapshot         Json
  createdAt        DateTime @default(now())

  @@index([workId, createdAt(sort: Desc)])
}

/// 作品下的多轮对话；共享同一份作品状态，messages 存 LangGraph thread checkpoint
model WorkConversation {
  id        String   @id @default(cuid())
  workId    String
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  title     String   @default("新对话")
  threadId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId, updatedAt(sort: Desc)])
}

model Publication {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workId        String?
  work          Work?     @relation(fields: [workId], references: [id], onDelete: SetNull)
  slug          String    @unique
  title         String
  excerpt       String?
  body          String
  coverUrl      String?
  platform      String?
  contentFormat String?
  topicCategory String?
  contentTopic  String?
  contentType   String?
  mediaType     String?
  hashtags      Json      @default("[]")
  images        Json      @default("[]")
  status        String    @default("draft")
  viewCount     Int       @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status, updatedAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, platform, publishedAt(sort: Desc)])
  @@index([status, contentFormat, publishedAt(sort: Desc)])
  @@index([status, topicCategory, publishedAt(sort: Desc)])
  @@index([status, mediaType, publishedAt(sort: Desc)])
}
