DATABASE_URL=postgresql://yougan:yougan@localhost:5432/yougan_api
JWT_SECRET=change-me-in-production
PORT=4000

# Optional Redis cache (leave empty to disable)
REDIS_URL=redis://localhost:6379

AGENT_URL=http://localhost:2024

# OSS: local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
PUBLIC_BASE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000

# Optional SMTP for password reset emails (logs reset link to console when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Yougan <noreply@yougan.local>

# Platform OAuth (see docs/platform-oauth.md in repo root)
# XIAOHONGSHU_OAUTH_CLIENT_ID=
# XIAOHONGSHU_OAUTH_CLIENT_SECRET=
# XIAOHONGSHU_OAUTH_AUTHORIZE_URL=
# XIAOHONGSHU_OAUTH_TOKEN_URL=
# XIAOHONGSHU_OAUTH_SCOPES=

# S3-compatible / Aliyun OSS (when STORAGE_DRIVER=s3)
OSS_ENDPOINT=
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
