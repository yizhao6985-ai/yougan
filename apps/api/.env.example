# =============================================================================
# Yougan API — 环境变量模板
# 复制为 .env：cp .env.example .env
# =============================================================================

# --- 数据库（Prisma 业务库，docker compose :5432）---
DATABASE_URL=postgresql://yougan:yougan@localhost:5432/yougan_api

# --- 服务 ---
PORT=4000

# WEB_APP_URL=http://localhost:3000
JWT_SECRET=change-me-in-production

# --- Agent 代理（LangGraph 服务地址，docker compose 外单独启动 :2024）---
AGENT_URL=http://localhost:2024

# --- RAG 客服 Agent（AG-UI /api/v1/chat 上游，默认 :8000）---
RAG_SERVICE_URL=http://localhost:8000

# --- 文件存储（local | oss）---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
# --- 可选：阿里云 OSS（STORAGE_DRIVER=oss 时必填 OSS_*）---
# OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
# OSS_REGION=oss-cn-shenzhen
# OSS_BUCKET=yougan-prod
# OSS_ACCESS_KEY_ID=
# OSS_SECRET_ACCESS_KEY=

# --- 可选：Redis 缓存（不设则禁用）---
# REDIS_URL=redis://localhost:6379

# --- 可选：前端地址（邮件中的链接，默认 http://localhost:3000）---
# WEB_APP_URL=http://localhost:3000
# WEB_APP_URL=https://www.yougan.xyz

# --- 可选：发布摘要 AI 增强（与 Agent 共用百炼密钥时可填）---
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_CHAT_MODEL=qwen-plus

# --- 可选：SMTP 发信（未配置时开发环境将重置链接打印到控制台）---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Yougan <noreply@yougan.local>