# =============================================================================
# Yougan API — 环境变量模板
# 复制为 .env：cp .env.example .env
# =============================================================================

# --- 数据库（Prisma 业务库，docker compose :5432）---
DATABASE_URL=postgresql://yougan:yougan@localhost:5432/yougan_api

# --- 服务 ---
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
JWT_SECRET=change-me-in-production

# --- Agent 代理（LangGraph 服务地址，docker compose 外单独启动 :2024）---
AGENT_URL=http://localhost:2024

# --- 文件存储（local | s3）---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage

# --- 可选：Redis 缓存（不设则禁用）---
# REDIS_URL=redis://localhost:6379

# --- 可选：前端地址（邮件中的链接，默认 http://localhost:3000）---
# WEB_APP_URL=http://localhost:3000

# --- 可选：SMTP 发信（未配置时开发环境将重置链接打印到控制台）---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Yougan <noreply@yougan.local>

# --- 可选：S3 兼容存储（STORAGE_DRIVER=s3 时必填 OSS_*）---
# OSS_ENDPOINT=
# OSS_REGION=auto
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_SECRET_ACCESS_KEY=

# --- 可选：平台 OAuth（见 docs/platform-oauth.md）---
# XIAOHONGSHU_OAUTH_CLIENT_ID=
# XIAOHONGSHU_OAUTH_CLIENT_SECRET=
# XIAOHONGSHU_OAUTH_AUTHORIZE_URL=
# XIAOHONGSHU_OAUTH_TOKEN_URL=
# XIAOHONGSHU_OAUTH_SCOPES=
