{
  "name": "@yougan/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#agent/state-io/*": "./src/state-io/*",
    "#agent/messages/*": "./src/messages/*",
    "#agent/llm/*": "./src/llm/*",
    "#agent/system-prompt.js": "./src/system-prompt.ts",
    "#agent/state.js": "./src/state.ts",
    "#agent/env.js": "./src/env.ts",
    "#agent/prompts/*": "./src/prompts/*"
  },
  "scripts": {
    "dev": "langgraphjs dev --port 2024 --no-browser",
    "build": "tsc --noEmit",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.3",
    "@langchain/langgraph": "^1.3.4",
    "@langchain/langgraph-checkpoint": "^1.0.4",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.2",
    "@yougan/domain": "workspace:*",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.2.0",
    "nanoid": "^5.1.11",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.2.4",
    "@types/node": "^24.12.4",
    "typescript": "^5.9.3"
  }
}
