# =============================================================================
# Yougan Agent — 环境变量模板
# 复制为 .env：cp .env.example .env
# =============================================================================

# --- 数据库（LangGraph checkpoint，docker compose :5433，独立于 API 业务库）---
POSTGRES_URI=postgresql://yougan:yougan@localhost:5433/yougan_agent

# --- 阿里百炼 DashScope（OpenAI 兼容模式，必填方可调用 LLM）---
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 模型 ID（未设置时使用 apps/agent/src/llm/models.ts 中的默认模型）---
# LLM_MODEL_CHAT=qwen3.7-max

# --- LangSmith 可观测性（可选；langgraphjs dev 与 LangChain 自动读取）---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=yougan
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
