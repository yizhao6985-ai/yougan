# =============================================================================
# Yougan Agent — 环境变量模板
# 复制为 .env 后填入密钥：cp .env.example .env
# =============================================================================

# --- 数据库（LangGraph checkpoint + 会话状态，独立于 API 业务库）---
POSTGRES_URI=postgresql://yougan:yougan@localhost:5433/yougan_agent

# --- LLM 通用默认 ---
# LLM_STREAMING=true
# MINIMAX_TEMPERATURE=0.7
# DEEPSEEK_TEMPERATURE=0.3

# --- MiniMax：主对话模型（Anthropic 兼容端点）---
# 国内：https://api.minimaxi.com/anthropic
# 海外：https://api.minimax.io/anthropic
MINIMAX_API_KEY=
MINIMAX_CHAT_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_CHAT_MODEL=MiniMax-M2.7
MINIMAX_MAX_TOKENS=8192
# MINIMAX_THINKING_TYPE=enabled
# MINIMAX_THINKING_BUDGET_TOKENS=2000

# --- DeepSeek：结构化输出（灵感选项轮 / 灵感推荐 / 灵感→大纲同步）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-flash

# --- LangSmith 可观测性（可选）---
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=yougan
