# =============================================================================
# Yougan Agent — 环境变量模板
# 复制为 .env：cp .env.example .env
# =============================================================================

# --- 数据库（LangGraph checkpoint，与 API 共用 Postgres :5432，独立库 yougan_agent）---
POSTGRES_URI=postgresql://yougan:yougan@localhost:5432/yougan_agent

# --- 百炼 DashScope（仅凭证；模型 ID 见 src/llm/providers/catalog.ts）---
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- LangSmith 可观测性（可选）---
# LANGSMITH_API_KEY=
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=yougan-agent
# LANGSMITH_TRACING=true

# --- Tavily API Key（用于搜索引擎）---
# TAVILY_API_KEY=
