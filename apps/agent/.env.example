# =============================================================================
# Yougan Agent — 环境变量模板
# 复制为 .env：cp .env.example .env
# =============================================================================

# --- 数据库（LangGraph checkpoint，docker compose :5433，独立于 API 业务库）---
POSTGRES_URI=postgresql://yougan:yougan@localhost:5433/yougan_agent

# --- Qwen（百炼 DashScope，OpenAI 兼容；对话与结构化 work）---
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen3.7-max

# --- MiniMax（OpenAI 兼容；多模态任务：参考素材分析等）---
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M3

# --- LangSmith 可观测性（可选）---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=yougan-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Tavily API Key（用于搜索引擎）---
# TAVILY_API_KEY=
